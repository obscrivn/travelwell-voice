# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Alternatively, for Gemini API via Google AI Studio,
# comment out the three lines above and uncomment:
# GEMINI_API_KEY=your-api-key-here

# Live Google Maps/Places API integrations
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# TravelWell Custom API Tool Security Key
TRAVELWELL_TOOL_API_KEY=

# Vocal Bridge Integration
VOCAL_BRIDGE_API_KEY=
VOCAL_BRIDGE_AGENT_ID=
VOCAL_BRIDGE_URL=https://vocalbridgeai.com

# Sabre MCP Integration
SABRE_MCP_TOKEN=
SABRE_PCC=
SABRE_MCP_URL=https://mcp2.cert.sabre.com/mcp

